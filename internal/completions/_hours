#compdef hours

local state

_arguments \
  '1:command:->cmds' \
  '2:client:->clients' \
  '3:task:->tasks'

case $state in
  cmds)
    _values "commands" add complete config delete get list new remove start stop task time version
    ;;
  clients)
    case $words[2] in
      new|delete|task|get|add|remove|rm|complete|start)
        _values "clients" $(hours ls -c)
        ;;
      config)
        _values "config commands" add-directory remove-directory list
        ;;
    esac
    ;;
  tasks)
    case $words[2] in
      add|remove|rm|complete|start)
        _values "tasks" $(hours get $words[3] -t)
        ;;
    esac
    ;;
esac
